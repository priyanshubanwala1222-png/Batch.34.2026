#!/bin/bash

# --- Initial OS Selection ---
echo "---------------------------"
echo "  SELECT OPERATING SYSTEM  "
echo "---------------------------"
echo "1) Amazon Linux"
echo "2) Red Hat (RHEL)"
echo "3) Exit"
read -p "Choose [1-3]: " os_type

if [ "$os_type" == "3" ] || [ -z "$os_type" ]; then
    exit 0
fi

# --- Management Loop ---
while true; do
    echo "---------------------------"
    echo "   NGINX MANAGEMENT TOOL   "
    echo "---------------------------"
    echo "1) Install Nginx"
    echo "2) Uninstall Nginx"
    echo "3) Start/Stop/Restart"
    echo "4) Check Status"
    echo "5) Exit"
    read -p "Select [1-5]: " choice

    case $choice in
        1)
            if [ "$os_type" == "1" ]; then
                echo "Installing on Amazon Linux..."
                sudo dnf install nginx -y || sudo amazon-linux-extras install nginx1 -y
            else
                echo "Installing on Red Hat..."
                sudo dnf install nginx -y
            fi
            sudo systemctl enable nginx --now
            echo "Nginx installed and started."
            ;;
        2)
            echo "Removing Nginx..."
            sudo dnf remove nginx -y || sudo yum remove nginx -y
            ;;
        3)
            read -p "Action (a)start (b)stop (c)restart: " action
            case $action in
                a) sudo systemctl start nginx ;;
                b) sudo systemctl stop nginx ;;
                c) sudo systemctl restart nginx ;;
                *) echo "Invalid action." ;;
            esac
            ;;
        4)
            systemctl status nginx --no-pager
            ;;
        5)
            echo "Exiting."
            exit 0
            ;;
        *)
            echo "Invalid option."
            ;;
    esac
    echo ""
done